{
  "name": "@salense/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @salense/api build && tsx src/cli.ts",
    "start": "node dist/cli.js",
    "worker:sync": "pnpm dev",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@salense/api": "workspace:*",
    "@salense/shared": "workspace:*",
    "bullmq": "5.34.2",
    "ioredis": "5.4.2"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.19.2"
  }
}
