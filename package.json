{
  "name": "salense",
  "version": "0.1.0",
  "private": true,
  "description": "Salense production SaaS monorepo foundation.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "demo:seed": "pnpm --filter @salense/worker exec tsx ../../scripts/seed.ts",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "jest --passWithNoTests && turbo run test",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@next/eslint-plugin-next": "15.1.4",
    "@playwright/test": "1.49.1",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.5",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "ts-jest": "29.2.5",
    "turbo": "2.3.3",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  }
}
