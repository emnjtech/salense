generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Phase 1 account identity for Salense users.
/// Authentication logic is intentionally not wired to this model yet.
model User {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String    @unique
  passwordHash    String
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?

  businesses              Business[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// Business profile required before store integrations are enabled.
/// Version 1 supports one business per account via the ownerId unique constraint;
/// the User.businesses relation remains future-friendly for multiple businesses.
model Business {
  id                     String  @id @default(cuid())
  ownerId                String  @unique
  name                   String
  tradingName            String?
  businessLogoUrl        String?
  country                String?
  timeZone               String?
  currency               String?
  taxPreference          String?
  industry               String?
  businessSize           String?
  defaultReportingPeriod String?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  connectedStores             ConnectedStore[]
  commerceOrders              CommerceOrder[]
  commerceOrderItems          CommerceOrderItem[]
  commerceProducts            CommerceProduct[]
  commerceCustomers           CommerceCustomer[]
  commerceInventorySnapshots  CommerceInventorySnapshot[]
  commerceCategories          CommerceCategory[]
  commerceRefunds             CommerceRefund[]
  commerceSyncCursors         CommerceSyncCursor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("businesses")
}

/// Supported commerce platforms for Version 1 store connections.
/// Future platforms must be added intentionally so unsupported integrations are rejected.
enum StorePlatform {
  WOOCOMMERCE
  AMAZON_SELLER
  TIKTOK_SHOP
  SHOPIFY
}

/// Internal Salense platform administration role.
/// Platform administrators are stored separately from customer business users.
enum PlatformAdminRole {
  SUPER_ADMIN
}

/// Internal Salense platform administrator account status.
enum PlatformAdminStatus {
  ACTIVE
  DISABLED
}

/// Internal Salense platform administrator.
/// Platform administrators never inherit customer business ownership.
model PlatformAdmin {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String
  firstName    String
  lastName     String
  role         PlatformAdminRole   @default(SUPER_ADMIN)
  status       PlatformAdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?

  refreshTokens PlatformAdminRefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("platform_admins")
}

/// Refresh token store for internal Platform Administration sessions.
/// Tokens are hashed and scoped to platform administrators only.
model PlatformAdminRefreshToken {
  id              String    @id @default(cuid())
  platformAdminId String
  tokenHash       String    @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  platformAdmin PlatformAdmin @relation(fields: [platformAdminId], references: [id], onDelete: Cascade)

  @@index([platformAdminId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("platform_admin_refresh_tokens")
}

/// Store connection lifecycle shown to users in the Store Integration Module.
enum StoreConnectionStatus {
  PENDING_VALIDATION
  CONNECTED
  SYNCHRONISING
  DISCONNECTED
  AUTHENTICATION_EXPIRED
  ERROR
}

/// Version 1 commerce resources synchronised from connected platforms.
enum CommerceSyncResource {
  ORDERS
  PRODUCTS
  CUSTOMERS
  INVENTORY
  CATEGORIES
  REFUNDS
}

/// Last known outcome for a per-resource synchronisation cursor.
enum CommerceSyncCursorStatus {
  SUCCESS
  ERROR
}

/// Read-only marketplace connection metadata for a business.
/// Salense never stores marketplace passwords; token fields store hashes or non-secret metadata only.
/// Disconnecting a store revokes future synchronisation without deleting historical analytics.
model ConnectedStore {
  id                   String                @id @default(cuid())
  businessId           String
  platform             StorePlatform
  storeName            String
  storeUrl             String?
  region               String?
  connectionStatus     StoreConnectionStatus @default(DISCONNECTED)
  accessTokenHash      String?
  accessTokenMetadata  Json?
  refreshTokenHash     String?
  refreshTokenMetadata Json?
  lastSynchronisedAt   DateTime?
  disconnectedAt       DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  commerceOrders             CommerceOrder[]
  commerceOrderItems         CommerceOrderItem[]
  commerceProducts           CommerceProduct[]
  commerceCustomers          CommerceCustomer[]
  commerceInventorySnapshots CommerceInventorySnapshot[]
  commerceCategories         CommerceCategory[]
  commerceRefunds            CommerceRefund[]
  commerceSyncCursors        CommerceSyncCursor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([platform])
  @@index([connectionStatus])
  @@index([lastSynchronisedAt])
  @@unique([businessId, platform, storeUrl, region])
  @@map("connected_stores")
}

/// Normalised read-only order imported from a connected commerce platform.
/// The source platform remains authoritative; Salense stores platform identity and raw metadata.
model CommerceOrder {
  id                   String        @id @default(cuid())
  businessId           String
  connectedStoreId     String
  platform             StorePlatform
  platformOrderId      String
  platformOrderNumber  String?
  orderStatus          String?
  currency             String?
  subtotalAmount       Decimal?
  totalAmount          Decimal?
  taxAmount            Decimal?
  shippingAmount       Decimal?
  discountAmount       Decimal?
  refundedAmount       Decimal?
  orderedAt            DateTime?
  platformCreatedAt    DateTime?
  platformUpdatedAt    DateTime?
  sourceMetadata       Json?
  importedAt           DateTime      @default(now())
  lastSyncedAt         DateTime      @default(now())

  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore      @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)
  items          CommerceOrderItem[]
  refunds        CommerceRefund[]

  @@unique([connectedStoreId, platformOrderId])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([orderedAt])
  @@index([orderStatus])
  @@index([businessId, orderedAt])
  @@map("commerce_orders")
}

/// Read-only order line item imported with its original platform item and product identifiers.
/// No automatic cross-platform product matching is performed in Version 1.
model CommerceOrderItem {
  id                   String        @id @default(cuid())
  businessId           String
  connectedStoreId     String
  commerceOrderId      String
  platform             StorePlatform
  platformOrderItemId  String
  platformProductId    String?
  platformVariationId  String?
  sku                  String?
  name                 String?
  quantity             Int?
  unitPriceAmount      Decimal?
  subtotalAmount       Decimal?
  totalAmount          Decimal?
  taxAmount            Decimal?
  sourceMetadata       Json?
  importedAt           DateTime      @default(now())
  lastSyncedAt         DateTime      @default(now())

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)
  order          CommerceOrder  @relation(fields: [commerceOrderId], references: [id], onDelete: Cascade)

  @@unique([commerceOrderId, platformOrderItemId])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([platformProductId])
  @@index([sku])
  @@map("commerce_order_items")
}

/// Normalised read-only product imported from one connected store.
/// Products from different platforms/stores intentionally remain distinct in Version 1.
model CommerceProduct {
  id                    String        @id @default(cuid())
  businessId            String
  connectedStoreId      String
  platform              StorePlatform
  platformProductId     String
  platformVariationId   String?
  sku                   String?
  name                  String?
  productType           String?
  productStatus         String?
  currency              String?
  priceAmount           Decimal?
  regularPriceAmount    Decimal?
  salePriceAmount       Decimal?
  stockStatus           String?
  currentStockQuantity  Int?
  platformCreatedAt     DateTime?
  platformUpdatedAt     DateTime?
  sourceMetadata        Json?
  importedAt            DateTime      @default(now())
  lastSyncedAt          DateTime      @default(now())

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)

  @@unique([connectedStoreId, platformProductId])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([platformProductId])
  @@index([sku])
  @@index([productStatus])
  @@index([stockStatus])
  @@map("commerce_products")
}

/// Normalised read-only customer imported from a connected commerce platform.
/// Customer identity is platform-scoped; cross-platform identity resolution is deferred.
model CommerceCustomer {
  id                    String        @id @default(cuid())
  businessId            String
  connectedStoreId      String
  platform              StorePlatform
  platformCustomerId    String
  email                 String?
  firstName             String?
  lastName              String?
  username              String?
  customerRole          String?
  platformCreatedAt     DateTime?
  platformUpdatedAt     DateTime?
  sourceMetadata        Json?
  importedAt            DateTime      @default(now())
  lastSyncedAt          DateTime      @default(now())

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)

  @@unique([connectedStoreId, platformCustomerId])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([platformCustomerId])
  @@index([email])
  @@map("commerce_customers")
}

/// Point-in-time read-only inventory state captured from platform product stock fields.
/// Inventory snapshots record what the source reported; Salense does not adjust marketplace stock.
model CommerceInventorySnapshot {
  id                    String        @id @default(cuid())
  businessId            String
  connectedStoreId      String
  platform              StorePlatform
  platformProductId     String
  sku                   String?
  stockQuantity         Int?
  stockStatus           String?
  manageStock           Boolean?
  capturedAt            DateTime      @default(now())
  sourceMetadata        Json?
  importedAt            DateTime      @default(now())
  lastSyncedAt          DateTime      @default(now())

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)

  @@unique([connectedStoreId, platformProductId, capturedAt])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([platformProductId])
  @@index([sku])
  @@index([stockStatus])
  @@index([capturedAt])
  @@map("commerce_inventory_snapshots")
}

/// Read-only product category imported from a connected commerce platform.
/// Category hierarchy remains platform-scoped through platformParentCategoryId.
model CommerceCategory {
  id                        String        @id @default(cuid())
  businessId                String
  connectedStoreId          String
  platform                  StorePlatform
  platformCategoryId        String
  platformParentCategoryId  String?
  name                      String?
  slug                      String?
  productCount              Int?
  sourceMetadata            Json?
  importedAt                DateTime      @default(now())
  lastSyncedAt              DateTime      @default(now())

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)

  @@unique([connectedStoreId, platformCategoryId])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([platformCategoryId])
  @@index([platformParentCategoryId])
  @@map("commerce_categories")
}

/// Normalised read-only refund imported from a connected commerce platform.
/// Refunds keep source order linkage through both CommerceOrder and the platform order ID.
model CommerceRefund {
  id                    String        @id @default(cuid())
  businessId            String
  connectedStoreId      String
  commerceOrderId       String?
  platform              StorePlatform
  platformRefundId      String
  platformOrderId       String?
  refundStatus          String?
  reason                String?
  currency              String?
  amount                Decimal?
  refundedAt            DateTime?
  sourceMetadata        Json?
  importedAt            DateTime      @default(now())
  lastSyncedAt          DateTime      @default(now())

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)
  order          CommerceOrder? @relation(fields: [commerceOrderId], references: [id], onDelete: SetNull)

  @@unique([connectedStoreId, platformRefundId])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([platformRefundId])
  @@index([platformOrderId])
  @@index([refundStatus])
  @@index([refundedAt])
  @@map("commerce_refunds")
}

/// Per-store, per-resource cursor for incremental read-only synchronisation.
/// Error metadata must remain safe and must not include credentials, token material, or raw marketplace payloads.
model CommerceSyncCursor {
  id                     String                   @id @default(cuid())
  businessId             String
  connectedStoreId       String
  platform               StorePlatform
  resource               CommerceSyncResource
  lastSuccessfulSyncedAt DateTime?
  lastAttemptedSyncedAt  DateTime?
  status                 CommerceSyncCursorStatus
  errorMetadata          Json?

  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connectedStore ConnectedStore @relation(fields: [connectedStoreId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([connectedStoreId, resource])
  @@index([businessId])
  @@index([connectedStoreId])
  @@index([platform])
  @@index([resource])
  @@index([status])
  @@index([lastSuccessfulSyncedAt])
  @@index([lastAttemptedSyncedAt])
  @@map("commerce_sync_cursors")
}

/// Permanent append-only audit history for important Salense activities.
/// Stores identifiers and safe metadata only; credential material and raw marketplace payloads are excluded by application services.
model AuditLog {
  id               String         @id @default(cuid())
  userId           String
  businessId       String
  action           String
  affectedModule   String
  affectedStoreId  String?
  affectedPlatform StorePlatform?
  result           String
  metadata         Json?
  createdAt        DateTime       @default(now())

  @@index([userId])
  @@index([businessId])
  @@index([action])
  @@index([affectedModule])
  @@index([affectedStoreId])
  @@index([affectedPlatform])
  @@index([result])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Public early-access subscription interest request.
/// This captures commercial intent only; payment processing is intentionally not implemented.
model SubscriptionInvitation {
  id                       String    @id @default(cuid())
  fullName                 String
  businessName             String
  workEmail                String
  phoneNumber              String?
  websiteUrl               String?
  preferredPlan            String
  platforms                Json
  message                  String?
  status                   String    @default("PENDING")
  invitationTokenHash      String?   @unique
  invitationTokenExpiresAt DateTime?
  invitationTokenUsedAt    DateTime?
  approvedAt               DateTime?
  rejectedAt               DateTime?
  archivedAt               DateTime?
  archivedByUserId         String?
  statusBeforeArchive      String?
  deletedAt                DateTime?
  deletedByUserId          String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([workEmail])
  @@index([preferredPlan])
  @@index([status])
  @@index([invitationTokenExpiresAt])
  @@index([archivedAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("subscription_invitations")
}

/// Hashed email verification token generated after registration.
/// Stores lookup and expiry state only; email delivery is intentionally not implemented yet.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

/// Hashed password reset token for time-limited account recovery.
/// Password hashing and reset execution are intentionally not implemented yet.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/// Hashed refresh token session used for configurable authenticated sessions.
/// Raw refresh tokens are never stored; revokedAt records logout/session invalidation.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}
