generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Phase 1 account identity for Salense users.
/// Authentication logic is intentionally not wired to this model yet.
model User {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String    @unique
  passwordHash    String
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?

  businesses              Business[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// Business profile required before store integrations are enabled.
/// Version 1 supports one business per account via the ownerId unique constraint;
/// the User.businesses relation remains future-friendly for multiple businesses.
model Business {
  id                     String  @id @default(cuid())
  ownerId                String  @unique
  name                   String
  tradingName            String?
  businessLogoUrl        String?
  country                String?
  timeZone               String?
  currency               String?
  taxPreference          String?
  industry               String?
  businessSize           String?
  defaultReportingPeriod String?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  connectedStores ConnectedStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("businesses")
}

/// Supported commerce platforms for Version 1 store connections.
/// Future platforms must be added intentionally so unsupported integrations are rejected.
enum StorePlatform {
  WOOCOMMERCE
  AMAZON_SELLER
  TIKTOK_SHOP
}

/// Store connection lifecycle shown to users in the Store Integration Module.
enum StoreConnectionStatus {
  CONNECTED
  SYNCHRONISING
  DISCONNECTED
  AUTHENTICATION_EXPIRED
  ERROR
}

/// Read-only marketplace connection metadata for a business.
/// Salense never stores marketplace passwords; token fields store hashes or non-secret metadata only.
/// Disconnecting a store revokes future synchronisation without deleting historical analytics.
model ConnectedStore {
  id                   String                @id @default(cuid())
  businessId           String
  platform             StorePlatform
  storeName            String
  storeUrl             String?
  region               String?
  connectionStatus     StoreConnectionStatus @default(DISCONNECTED)
  accessTokenHash      String?
  accessTokenMetadata  Json?
  refreshTokenHash     String?
  refreshTokenMetadata Json?
  lastSynchronisedAt   DateTime?
  disconnectedAt       DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([platform])
  @@index([connectionStatus])
  @@index([lastSynchronisedAt])
  @@unique([businessId, platform, storeUrl, region])
  @@map("connected_stores")
}

/// Hashed email verification token generated after registration.
/// Stores lookup and expiry state only; email delivery is intentionally not implemented yet.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

/// Hashed password reset token for time-limited account recovery.
/// Password hashing and reset execution are intentionally not implemented yet.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/// Hashed refresh token session used for configurable authenticated sessions.
/// Raw refresh tokens are never stored; revokedAt records logout/session invalidation.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}
